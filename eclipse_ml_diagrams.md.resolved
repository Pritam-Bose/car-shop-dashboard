## 5. Speech Emotion Pipeline

```mermaid
flowchart TD
    classDef fe fill:#7B68EE,stroke:#4B3FA0,color:#fff
    classDef proc fill:#1ABC9C,stroke:#0E6655,color:#fff
    classDef feat fill:#E67E22,stroke:#784212,color:#fff
    classDef model fill:#8E44AD,stroke:#5B2C6F,color:#fff
    classDef out fill:#27AE60,stroke:#145A32,color:#fff

    subgraph FRONT2["Frontend — useAudioRecorder"]
        MIC["Mic Button pressed"]:::fe
        REC2["AudioRecorderPlayer\nrecord eclipse_recording.wav"]:::fe
        STOP["Stop → upload WAV"]:::fe
    end

    subgraph BACK2["Backend — AudioProcessor via librosa"]
        LOAD["Load audio sr=16000 mono"]:::proc
        SR2["Speech Rate\nonset_detect → WPM"]:::feat
        SIL["Silence Duration\nRMS below 5 percent max → ms"]:::feat
        PITCH["Pitch Features\nmean / std / min / max Hz"]:::feat
        ENERGY["Energy Features\nRMS mean / std / min / max"]:::feat
        MFCC["MFCC 13 coefficients\nmean across time"]:::feat
        TRANS["STT Transcription\nSpeechRecognition → text"]:::proc
    end

    subgraph MODEL["Speech Emotion Model"]
        RULES["Rule Engine\nfast + high energy → joy\nslow + silence → sadness\nhigh pitch + energy → anger\nlow pitch + energy → fear"]:::model
        PROB["Probability Vector P7"]:::model
        EMO2["Speech Emotion + confidence"]:::out
    end

    MIC --> REC2 --> STOP --> LOAD
    LOAD --> SR2 & SIL & PITCH & ENERGY & MFCC & TRANS
    SR2 & SIL & PITCH & ENERGY & MFCC --> RULES --> PROB --> EMO2
```

