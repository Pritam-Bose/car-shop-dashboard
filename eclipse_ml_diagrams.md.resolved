## 3. BERT Text Emotion Model

```mermaid
flowchart TD
    classDef raw    fill:#2980B9,stroke:#1A5276,color:#fff
    classDef proc   fill:#8E44AD,stroke:#5B2C6F,color:#fff
    classDef model  fill:#D35400,stroke:#784212,color:#fff
    classDef sfx    fill:#C0392B,stroke:#7B241C,color:#fff
    classDef prob   fill:#2C3E50,stroke:#1A252F,color:#fff
    classDef argx   fill:#E74C3C,stroke:#922B21,color:#fff
    classDef gate   fill:#F39C12,stroke:#7D6608,color:#fff
    classDef fall   fill:#7F8C8D,stroke:#4D5656,color:#fff
    classDef norm   fill:#16A085,stroke:#0E6655,color:#fff
    classDef happy  fill:#F1C40F,stroke:#9A7D0A,color:#222
    classDef sad    fill:#5D6D7E,stroke:#2E4057,color:#fff
    classDef neut   fill:#27AE60,stroke:#145A32,color:#fff

    RAW["Raw User Text"]:::raw
    CLEAN["Text Cleaner\nlower-case · strip whitespace"]:::proc
    TOK["BERT Tokenizer\nCLS t1 t2 ... tn SEP\nmax_length=128 tokens"]:::proc
    ENC["BERT-base-uncased Encoder\n12 Transformer layers\n768 hidden · 12 heads · 110M params"]:::model
    CLS["CLS Token Pooling\nh_cls = H at position 0\n768-dim sentence vector"]:::model
    HEAD["Linear Classification Head\nz = W_c · h_cls + b_c\n768 → 7 logits"]:::model

    SOFT["SOFTMAX\nP(E | x) = exp(z_i) / Σ exp(z_j)\n→ Emotion Probability Distribution"]:::sfx

    P1["Joy\nP1"]:::prob
    P2["Sadness\nP2"]:::prob
    P3["Anger\nP3"]:::prob
    P4["Fear\nP4"]:::prob
    P5["Surprise\nP5"]:::prob
    P6["Disgust\nP6"]:::prob
    P7["Neutral\nP7"]:::prob

    ARGMAX["ARGMAX\nE_text = argmax P(E | x)\nc = max probability value"]:::argx

    GATE{"Confidence Gate\nc >= 0.5 ?"}:::gate
    FALL["Fallback\n→ neutral · c = 1.0"]:::fall

    NORM["_normalize_emotion()\njoy / happiness / excited  → joy\nsad / depression / negative → sadness\nneutral / ok / normal      → neutral"]:::norm

    H["HAPPY\nwarm tone · max 100 tokens"]:::happy
    S["SAD\nempathetic tone · max 120 tokens"]:::sad
    N["NEUTRAL\nhelpful tone · max 150 tokens"]:::neut

    RAW --> CLEAN --> TOK --> ENC --> CLS --> HEAD --> SOFT
    SOFT --> P1 & P2 & P3 & P4 & P5 & P6 & P7
    P1 & P2 & P3 & P4 & P5 & P6 & P7 --> ARGMAX
    ARGMAX --> GATE
    GATE -->|"c < 0.5"| FALL
    GATE -->|"c >= 0.5"| NORM
    NORM --> H & S & N
```

