## 6. Facial Detection and Emotion Pipeline

```mermaid
flowchart TD
    classDef fe fill:#7B68EE,stroke:#4B3FA0,color:#fff
    classDef priv fill:#E74C3C,stroke:#922B21,color:#fff
    classDef proc fill:#1ABC9C,stroke:#0E6655,color:#fff
    classDef model fill:#E67E22,stroke:#784212,color:#fff
    classDef out fill:#27AE60,stroke:#145A32,color:#fff
    classDef gate fill:#F39C12,stroke:#7D6608,color:#fff

    subgraph FRONT3["Frontend — Delta Button"]
        DELTA["Delta Button pressed"]:::fe
        PERM["Permission Modal Consent"]:::fe
        CAP["takePhoto every 3s\nspeed priority · no shutter"]:::fe
        UPLOAD["POST /face — single frame JPEG"]:::fe
    end

    subgraph BACK3["Backend — ImageProcessor via OpenCV"]
        LOAD2["Load image cv2.imdecode"]:::proc
        GREY["Convert to grayscale"]:::proc
        HAAR["Haar Cascade detectMultiScale\nscaleFactor 1.1 · minNeighbors 5"]:::proc
        FACE{"Face detected?"}:::gate
        CROP["Extract + pad face region"]:::proc
        RESIZE["Resize 48x48 · Normalize 0-1"]:::proc
        DISCARD["Raw image DISCARDED\nonly feature vector forwarded"]:::priv
    end

    subgraph MODEL2["CNN Face Emotion Model"]
        CNN2["FER CNN Backbone\nResNet-50 or lightweight variant"]:::model
        FACS["FACS Action Units\nAU4 AU6 AU12 AU17"]:::model
        EAR2["Geometric Landmarks\nEAR · MAR · 68-point mesh"]:::model
        SOFT2["Softmax P7\nP(E|I) = softmax(Wc · phi(I) + bc)"]:::model
        EMO3["Face Emotion + confidence · weight lambda3"]:::out
    end

    DELTA --> PERM --> CAP --> UPLOAD
    UPLOAD --> LOAD2 --> GREY --> HAAR --> FACE
    FACE -->|No face| EMO3
    FACE -->|Yes| CROP --> RESIZE --> DISCARD --> CNN2
    CNN2 --> SOFT2 --> EMO3
    FACS & EAR2 -.->|Feature input layers| CNN2
```

