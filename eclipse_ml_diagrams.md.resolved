## 7. Multimodal Fusion Engine

```mermaid
flowchart TB
    classDef sig    fill:#3498DB,stroke:#1A5276,color:#fff
    classDef weight fill:#9B59B6,stroke:#5B2C6F,color:#fff
    classDef agg    fill:#27AE60,stroke:#145A32,color:#fff
    classDef ctx    fill:#E67E22,stroke:#784212,color:#fff
    classDef out    fill:#E74C3C,stroke:#922B21,color:#fff
    classDef theory fill:#1A1A2E,stroke:#4A4AFF,color:#cdf,font-style:italic

    subgraph THEORY["Fusion Theory"]
        direction TB
        F71["7.1 General Form\nE_final = sum_i( w_i · E_i )\nconstraint: sum_i( w_i ) = 1"]:::theory
        F72["7.2 Classical Fixed\nE_final = L1·E_text + L2·E_typing + L3·E_optional\nL1=0.9  L2=0.1  L3=0 (reserved)"]:::theory
        F73["7.3 Confidence-Weighted Adaptive\nw_i = (base_i · min(1, c_i·k)) / sum_j(base_j · min(1,c_j·k))\nk=2.0  min_conf=0.3"]:::theory
        F71 --> F72 --> F73
    end

    subgraph SIGNALS["Emotion Signals In"]
        direction TB
        TE["Text Emotion\nbase 0.5"]:::sig
        VE["Voice Emotion\nbase 0.3"]:::sig
        FE3["Face Emotion\nbase 0.15"]:::sig
        HE["Hesitation Score\nbase 0.05"]:::sig
    end

    subgraph WCALC["Weight Calculator (7.3)"]
        direction TB
        CHK["conf < 0.3 → w = 0"]:::weight
        SC["w_i = base_i · min(1, c_i · 2)"]:::weight
        NRM["Normalize: sum(w_i) = 1"]:::weight
        CHK --> SC --> NRM
    end

    subgraph AGG["Emotion Aggregator (7.1)"]
        direction TB
        WAVG["E_final = sum_i(w_i · P_i) over P7"]:::agg
        HADJ["High hesitation → boost neutral"]:::agg
        RNRM["Re-normalize probabilities"]:::agg
        ARGM["argmax → emotion + confidence"]:::agg
        WAVG --> HADJ --> RNRM --> ARGM
    end

    subgraph CTX["Context Builder"]
        direction TB
        CAT["Category\npositive / negative / neutral / ambiguous"]:::ctx
        TONE["Tone: conf >= 0.5 → specific\nelse → neutral"]:::ctx
        CAT --> TONE
    end

    FCTX["Fused Context\nemotion · confidence · tone · probabilities"]:::out

    THEORY -. "implements" .-> WCALC
    TE & VE & FE3 & HE --> CHK
    NRM --> WAVG
    ARGM --> CAT
    TONE --> FCTX
```

